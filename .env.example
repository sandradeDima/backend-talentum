DATABASE_URL="mysql://root:password@localhost:3306/talentum"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

AUTH_SECRET="replace_with_a_long_secret"
AUTH_BASE_URL="http://localhost:4000"

GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
MICROSOFT_CLIENT_ID="your_microsoft_client_id"
MICROSOFT_CLIENT_SECRET="your_microsoft_client_secret"
MICROSOFT_TENANT_ID="common"

SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="Talentum <no-reply@example.com>"

UPLOAD_DIR="storage/uploads"
MAX_UPLOAD_SIZE_MB=5

INVITATION_TOKEN_EXPIRES_HOURS=72
PASSWORD_RESET_TOKEN_EXPIRES_HOURS=24
SURVEY_RESPONSE_SESSION_EXPIRES_HOURS=8
SURVEY_ACCESS_CREDENTIAL_EXPIRES_HOURS=168
SURVEY_INVITATION_EMAIL_CONCURRENCY=5

LOG_LEVEL="info"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=600
AUTH_RATE_LIMIT_MAX_REQUESTS=40
SURVEY_ACCESS_RATE_LIMIT_MAX_REQUESTS=120
CSRF_COOKIE_NAME="cooltura_csrf"
DATABASE_CONTRACT_CHECK_ENABLED=true

WORKER_TICK_RETRY_ATTEMPTS=3
WORKER_TICK_RETRY_DELAY_MS=500

REMINDER_WORKER_ENABLED=true
REMINDER_WORKER_INTERVAL_SECONDS=60
REMINDER_BATCH_SIZE=10
REMINDER_MAX_RETRIES=3
REMINDER_DISPATCH_MAX_RETRIES=3
REMINDER_RETRY_DELAY_SECONDS=300
REMINDER_CREDENTIAL_EXPIRES_HOURS=72

DASHBOARD_ANONYMITY_MIN_COUNT=5
DASHBOARD_EXPORT_WORKER_ENABLED=true
DASHBOARD_EXPORT_WORKER_INTERVAL_SECONDS=60
DASHBOARD_EXPORT_BATCH_SIZE=5
DASHBOARD_EXPORT_MAX_RETRIES=3
DASHBOARD_EXPORT_RETRY_DELAY_SECONDS=300
